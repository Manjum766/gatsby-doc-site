{
  "name": "my-gatsby-site",
  "version": "1.0.0",
  "homepage": "https://Manjum766.github.io/gatsby-doc-site",
  "private": true,
  "description": "my-gatsby-site",
  "author": "Manjum766",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "deploy": "gatsby build --prefix-paths && gh-pages -d public",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "lint": "eslint src --ext .js,.jsx --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,md,css}\""
  },
  "dependencies": {
    "gatsby": "^5.14.6",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "gh-pages": "^6.3.0",
    "prettier": "^3.2.5"
  }
}
